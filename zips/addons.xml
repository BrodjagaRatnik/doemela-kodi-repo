<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.doemela" name="Doemela Repository" version="2.0.1" provider-name="Doemela">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Doemela Repository">
<dir>
    <info compressed="false">https://raw.githubusercontent.com/BrodjagaRatnik/doemela-kodi-repo/main/zips/addons.xml</info>
    <checksum>https://raw.githubusercontent.com/BrodjagaRatnik/doemela-kodi-repo/main/zips/addons.xml.md5</checksum>
    <datadir zip="true">https://raw.githubusercontent.com/BrodjagaRatnik/doemela-kodi-repo/main/zips/</datadir>
</dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>BrodjagaRatnik Clock Overlay Repo</summary>
        <description>Personal repository for the Clock Overlay addon on Raspberry Pi 5.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="script.clock.overlay" name="Clock Overlay" version="1.7.0" provider-name="Doemela">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.script" library="main.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Clock Overlay</summary>
        <description lang="en_GB">Displays a temporary clock overlay. Press '0' during playback to see the time.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
</addons>
